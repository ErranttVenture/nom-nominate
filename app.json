{
  "expo": {
    "name": "Nom Nominate",
    "slug": "nom-nominate",
    "owner": "errantventure",
    "version": "1.1.0",
    "orientation": "portrait",
    "scheme": "nomnominate",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1a1a2e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nomnominate.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.nomnominate.app",
      "versionCode": 25,
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "nom-nominate.web.app",
              "pathPrefix": "/party"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-firebase/messaging"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e933dfe6-278a-4280-af27-3f928dc61b1f"
      }
    }
  }
}
